# DashScope (Alibaba Cloud Model Studio / 百炼) — required for ASR and summarization
DASHSCOPE_API_KEY=

# MinIO — required. Endpoint MUST be a publicly reachable HTTPS API endpoint
# (NOT the management console URL) so DashScope can fetch the audio.
MINIO_ENDPOINT=https://minio.example.com
MINIO_BUCKET=bili-text-audio
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Bilibili — optional. When set, passed directly as a Cookie header to yt-dlp.
# Leave empty for anonymous access.
BILI_COOKIE=

# Model overrides — optional. Defaults are used when empty.
# ASR_MODEL=qwen3-asr-flash
# SUMMARY_MODEL=deepseek-v4-flash
